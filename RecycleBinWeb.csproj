<?xml version='1.0' encoding='utf-8'?>
<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>RecycleBinWeb</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Platforms>x64</Platforms>
    <ApplicationIcon>app.ico</ApplicationIcon>
    <AssemblyName>RecycleBinWeb</AssemblyName>
    <Version>1.0.4</Version>
    <Authors>Hadi Cahyadi</Authors>
    <Company>cumulus13</Company>
    <Product>RecycleBin On Web</Product>
    <Description>A professional web UI for the Windows Recycle Bin — list, search, restore, and permanently delete files directly from your browser. Built with **ASP.NET Core 8** and pure HTML/CSS/JS.</Description>
    <Copyright>Copyright © 2026</Copyright>
    
  </PropertyGroup>

  <ItemGroup>
    
  </ItemGroup>

</Project>